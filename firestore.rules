rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId)   { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Accounts ──────────────────────────────────────────────────────
    // FIX VULN-05: soldCount must increase, not be set arbitrarily
    // FIX F-06: credentials[] is PRIVATE — only admin can read full doc with credentials
    match /accounts/{accountId} {
      // Public: anyone can read listing (but credentials are in private subcollection)
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
            request.resource.data.views == resource.data.views + 1)
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['soldCount', 'status']) &&
            resource.data.status == 'available' &&
            request.resource.data.soldCount > resource.data.soldCount &&
            request.resource.data.soldCount <= resource.data.get('quantity', 1) &&
            request.resource.data.status == 'sold')
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['soldCount']) &&
            resource.data.status == 'available' &&
            request.resource.data.soldCount > resource.data.soldCount &&
            request.resource.data.soldCount <= resource.data.get('quantity', 1));
    }

    // ── Account Credentials (PRIVATE subcollection) ───────────────────
    // FIX F-06: credentials moved to accounts/{id}/credentials/slots
    // ONLY admin can read/write; buyers get credentials via their order record only
    match /accounts/{accountId}/credentials/{docId} {
      allow read, write: if isAdmin();
    }
    }

    // ── Users ──────────────────────────────────────────────────────────
    // FIX VULN-01,02: REMOVE isOwner balance increase — only server/admin can increase balance
    // FIX VULN-06: REMOVE !isAuthenticated() read — only owner/admin can read
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.balance == 0;
      allow update: if isAdmin()
        || (isOwner(userId) &&
            !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['balance', 'role', 'uid', 'createdAt']) &&
            request.resource.data.get('displayName', '').size() <= 100)
        // Checkout only: user can only DECREASE balance (never increase)
        || (isOwner(userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
            request.resource.data.balance < resource.data.balance &&
            request.resource.data.balance >= 0)
        // Server webhook: credit balance (unauthenticated REST call)
        || (!isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['balance', 'updatedAt']) &&
            request.resource.data.balance >= 0);
    }

    // ── Orders ────────────────────────────────────────────────────────
    // FIX VULN-03: restrict allowed fields in create
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.paymentMethod == 'balance'
        && request.resource.data.total >= 0
        && request.resource.data.keys().hasOnly([
            'userId','userEmail','userName','items','subtotal',
            'bulkDiscount','bulkRuleId','voucherDiscount','discount',
            'voucherCode','total','paymentMethod','status','createdAt','idempotencyKey'
           ]);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Topups ────────────────────────────────────────────────────────
    // FIX VULN-04: only unauthenticated server can create topups (not client)
    match /topups/{topupId} {
      allow read: if (isAuthenticated() && isOwner(resource.data.userId)) || isAdmin();
      allow create: if !isAuthenticated()
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 50000000
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0;
      allow update: if isAdmin()
        || (!isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status','autoApproved','sePayId','gateway','referenceCode','approvedAt']));
      allow delete: if false;
    }

    // ── Transactions ──────────────────────────────────────────────────
    match /transactions/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if !isAuthenticated() || isAdmin();
      allow update, delete: if false;
    }

    // ── Vouchers ──────────────────────────────────────────────────────
    // FIX VULN-07: user can only add THEIR OWN email to usedBy (not others)
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usedCount', 'usedBy']) &&
            request.resource.data.usedCount == resource.data.usedCount + 1 &&
            request.resource.data.usedBy.hasAll(resource.data.get('usedBy', [])) &&
            request.resource.data.usedBy.size() == resource.data.get('usedBy', []).size() + 1);
    }

    // ── Game Types ────────────────────────────────────────────────────
    match /gameTypes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Flash Sales ───────────────────────────────────────────────────
    match /flashSales/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Bulk Discount Rules ───────────────────────────────────────────
    match /bulkDiscountRules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Services ──────────────────────────────────────────────────────
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Service Orders ────────────────────────────────────────────────
    // FIX VULN-20: validate amount > 0
    match /serviceOrders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.get('amount', 0) > 0;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Unmatched Topups ──────────────────────────────────────────────
    // FIX VULN-10: only server (unauthenticated) can create
    match /unmatchedTopups/{id} {
      allow read: if isAdmin();
      allow create: if !isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── Processed Webhooks ────────────────────────────────────────────
    // FIX VULN-08: only server (unauthenticated) can create — not any anonymous user
    match /processedWebhooks/{id} {
      allow read: if isAdmin() || !isAuthenticated();
      allow create: if !isAuthenticated();
      allow update, delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
    }

    // ── Tickets ───────────────────────────────────────────────────────
    match /tickets/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Referrals ─────────────────────────────────────────────────────
    // FIX VULN-09: newUserId must be self, credited=false, cannot refer yourself
    match /referrals/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.newUserId == request.auth.uid ||
         resource.data.referrerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.newUserId == request.auth.uid
        && request.resource.data.credited == false
        && request.resource.data.referrerId != request.auth.uid;
      allow update: if isAdmin() || !isAuthenticated();
      allow delete: if false;
    }

    // ── Ratings ───────────────────────────────────────────────────────
    // FIX VULN-11: validate stars range and comment length
    match /ratings/{id} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('stars', 0) >= 1
        && request.resource.data.get('stars', 0) <= 5
        && request.resource.data.get('comment', '').size() <= 500;
      allow update, delete: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Wishlists ─────────────────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Audit Log ─────────────────────────────────────────────────────
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
