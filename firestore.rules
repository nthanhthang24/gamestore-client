rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId)   { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ══════════════════════════════════════════════════════════════════════
    // ACCOUNTS
    // ══════════════════════════════════════════════════════════════════════
    match /accounts/{accountId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Chỉ admin update. Views: bất kỳ ai tăng đúng +1.
      allow update: if isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
            request.resource.data.views == resource.data.views + 1);
    }

    // ── Credentials subcollection ─────────────────────────────────────────
    // FIX-FINAL: CHỈ admin (Admin SDK) đọc/ghi được.
    // Client (CartPage) KHÔNG còn đọc credentials nữa.
    // Server /checkout/confirm dùng Admin SDK để:
    //   1. Fetch credentials subcollection
    //   2. Inject vào order record
    //   3. Update soldCount
    // Buyer đọc credentials từ ORDER record (đã được copy vào order).
    // → Không có bất kỳ user login nào đọc được credentials của account chưa mua.
    match /accounts/{accountId}/credentials/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // USERS
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.balance == 0;
      allow update: if isAdmin()
        // Profile update: chỉ displayName, avatar — không được đụng balance/role/uid/banned/email
        || (isOwner(userId) &&
            !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['balance', 'role', 'uid', 'createdAt',
                                      'banned', 'bannedAt', 'email']) &&
            request.resource.data.get('displayName', '').size() <= 100)
        // Checkout: user tự GIẢM balance (thanh toán)
        // Không được tăng, không được giảm quá 10M/lần (giới hạn single purchase)
        // → Ngăn attacker set balance = 0 để social engineer "mất tiền"
        || (isOwner(userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
            request.resource.data.balance < resource.data.balance &&
            request.resource.data.balance >= 0 &&
            resource.data.balance - request.resource.data.balance <= 10000000);
        // Server webhook dùng Admin SDK bypass rules để credit balance
    }

    // ══════════════════════════════════════════════════════════════════════
    // ORDERS
    // ══════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.paymentMethod == 'balance'
        && request.resource.data.total > 0
        && request.resource.data.total <= 100000000
        && request.resource.data.get('items', []).size() > 0
        && request.resource.data.items[0].id is string
        && request.resource.data.items[0].id.size() > 0
        && request.resource.data.items[0].get('price', 0) > 0
        && request.resource.data.keys().hasOnly([
            'userId','userEmail','userName','items','subtotal',
            'bulkDiscount','bulkRuleId','voucherDiscount','discount',
            'voucherCode','total','paymentMethod','status','createdAt','idempotencyKey'
           ]);
      // Server Admin SDK bypass rules — không cần rule client cho update
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // TOPUPS
    // FIX V4: Chỉ authenticated user tạo topup cho chính mình.
    // ══════════════════════════════════════════════════════════════════════
    match /topups/{topupId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.status == 'pending'
            && request.resource.data.amount > 0
            && request.resource.data.amount <= 50000000);
      // Server Admin SDK update — chỉ admin cần rule
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // TRANSACTIONS — chỉ Admin SDK ghi
    // ══════════════════════════════════════════════════════════════════════
    match /transactions/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // VOUCHERS
    // ══════════════════════════════════════════════════════════════════════
    match /vouchers/{voucherId} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
              !resource.data.keys().hasAny(['targetUserId']) ||
              resource.data.get('targetUserId', '') == '' ||
              resource.data.targetUserId == request.auth.uid
            ));
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usedCount', 'usedBy']) &&
            request.resource.data.usedCount == resource.data.usedCount + 1 &&
            request.resource.data.usedBy.hasAll(resource.data.get('usedBy', [])) &&
            request.resource.data.usedBy.size() == resource.data.get('usedBy', []).size() + 1 &&
            request.resource.data.usedBy.hasAll([request.auth.token.email]));
    }

    // ══════════════════════════════════════════════════════════════════════
    // GAME TYPES / FLASH SALES / SERVICES — public read, admin write
    // ══════════════════════════════════════════════════════════════════════
    match /gameTypes/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /flashSales/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /services/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /bulkDiscountRules/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // ══════════════════════════════════════════════════════════════════════
    // SERVICE ORDERS
    // amount > 0 check tại Firestore level — client whitelist fields trong code
    // ══════════════════════════════════════════════════════════════════════
    match /serviceOrders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.get('amount', 0) > 0
        && request.resource.data.get('amount', 0) <= 100000000;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // UNMATCHED TOPUPS / PROCESSED WEBHOOKS — chỉ Admin SDK
    // FIX V3: Không có unauthenticated access — Admin SDK bypass rules
    // ══════════════════════════════════════════════════════════════════════
    match /unmatchedTopups/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /processedWebhooks/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS
    // ══════════════════════════════════════════════════════════════════════
    match /notifications/{id} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
              resource.data.get('targetAll', false) == true ||
              resource.data.get('targetUserId', '') == request.auth.uid
            ));
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.targetAll == false
            && request.resource.data.createdBy == 'system'
            && request.resource.data.get('targetUserId', request.auth.uid) == request.auth.uid
            // Giới hạn content size — tránh spam storage
            && request.resource.data.get('title', '').size() <= 100
            && request.resource.data.get('body', '').size() <= 500);
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
    }

    // ══════════════════════════════════════════════════════════════════════
    // TICKETS
    // FIX V13: Validate required fields + description limit tại rules level
    // hasOpenTicket check là UI gate — Firestore rules không thể query existence
    // Ticket per order limit cần Cloud Function (không thể enforce ở rules)
    // ══════════════════════════════════════════════════════════════════════
    match /tickets/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.get('orderId', '').size() > 0
        && request.resource.data.get('orderId', '').size() <= 64
        && request.resource.data.get('description', '').size() >= 10
        && request.resource.data.get('description', '').size() <= 2000
        // Require type field be one of known values
        && request.resource.data.get('type', '') in ['warranty', 'wrong_account', 'other'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // REFERRALS
    // ══════════════════════════════════════════════════════════════════════
    match /referrals/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.newUserId == request.auth.uid ||
         resource.data.referrerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.newUserId == request.auth.uid
        && request.resource.data.credited == false
        && request.resource.data.referrerId != request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // RATINGS
    // FIX V12: accountId required, comment >= 1 char, stars 1-5
    // Duplicate prevention: Firestore rules không query được collection khác,
    // nên unique constraint userId+accountId phải dùng composite docId trên client.
    // Client dùng setDoc(doc(db,'ratings', userId+'_'+accountId), ...) thay addDoc.
    // Rule: allow create với điều kiện document chưa tồn tại (implicit trong create).
    // ══════════════════════════════════════════════════════════════════════
    match /ratings/{id} {
      allow read: if true;
      // FIX V12: allow create AND update (setDoc overwrites existing doc)
      // docId = userId_accountId → unique constraint per user per account
      // User có thể update rating của chính mình (thay đổi sao/comment)
      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('stars', 0) >= 1
        && request.resource.data.get('stars', 0) <= 5
        && request.resource.data.get('comment', '').size() >= 1
        && request.resource.data.get('comment', '').size() <= 500
        && request.resource.data.get('accountId', '').size() > 0
        && request.resource.data.keys().hasAny(['orderId'])
        && request.resource.data.get('orderId', '').size() > 0
        // Không được thay đổi userId, accountId, orderId sau khi tạo
        && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // SETTINGS / WISHLISTS / AUDIT LOGS
    // ══════════════════════════════════════════════════════════════════════
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.keys().hasAny(['action'])
        && request.resource.data.get('action', '').size() > 0
        && request.resource.data.get('action', '').size() <= 100;
      allow update, delete: if false;
    }
  }
}
