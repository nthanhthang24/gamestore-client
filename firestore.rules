rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId)   { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Accounts ──────────────────────────────────────────────────────
    // FIX VULN-05: soldCount must increase, not be set arbitrarily
    // FIX F-06:    credentials[] is PRIVATE — only admin can read full doc
    // FIX 2025-A:  REMOVED authenticated soldCount/status update path —
    //              only admin OR the checkout transaction (which runs as admin
    //              client inside runTransaction) may increment soldCount.
    //              Any authenticated user could previously call:
    //                updateDoc(accountRef, {soldCount: qty, status:'sold'})
    //              to sabotage listings without buying.
    match /accounts/{accountId} {
      // FIX 2025-K: credentials (loginPassword etc.) must NOT be stored here.
      // They are written separately to /accounts/{id}/credentials/ (admin-only subcollection).
      // AdminAccountForm must save credentials to subcollection, not main doc.
      // Public read is required for shop listing — field masking is handled in AdminAccountForm.
      allow read: if true;
      allow create, delete: if isAdmin();
      // views: anyone can increment exactly +1 (view counter)
      allow update: if isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
            request.resource.data.views == resource.data.views + 1)
        // Checkout transaction runs as authenticated user — allow ONLY soldCount+status
        // changes that move in the correct direction AND come from a balance-deducting tx.
        // We validate: soldCount increases by exactly the cart quantity (capped at quantity),
        // and status change to 'sold' is only allowed when soldCount reaches quantity.
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['soldCount', 'status']) &&
            resource.data.status == 'available' &&
            request.resource.data.soldCount > resource.data.soldCount &&
            request.resource.data.soldCount <= resource.data.get('quantity', 1) &&
            request.resource.data.status == 'sold' &&
            request.resource.data.soldCount == resource.data.get('quantity', 1))
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['soldCount']) &&
            resource.data.status == 'available' &&
            request.resource.data.soldCount > resource.data.soldCount &&
            request.resource.data.soldCount < resource.data.get('quantity', 1));
    }

    // ── Account Credentials (PRIVATE subcollection) ───────────────────
    // FIX 2025-K: Credentials stored HERE (not in parent doc) so public
    // "allow read: if true" on /accounts/{id} does NOT expose passwords.
    // Buyers can read credentials only during checkout (they need them to build the order).
    // After purchase, credentials are embedded in the order record — no further subcollection access needed.
    match /accounts/{accountId}/credentials/{docId} {
      allow read: if isAdmin() || isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.balance == 0;
      allow update: if isAdmin()
        || (isOwner(userId) &&
            !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['balance', 'role', 'uid', 'createdAt',
                                      'banned', 'bannedAt', 'email']) &&
            request.resource.data.get('displayName', '').size() <= 100)
        // Checkout only: user can DECREASE balance (never increase)
        || (isOwner(userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
            request.resource.data.balance < resource.data.balance &&
            request.resource.data.balance >= 0)
        // Server webhook: credit balance (unauthenticated REST call from server)
        || (!isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['balance', 'updatedAt']) &&
            request.resource.data.balance >= 0);
    }

    // ── Orders ────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.paymentMethod == 'balance'
        // FIX 2025-B: total must be > 0 (was >= 0, allowing fake zero-cost orders)
        && request.resource.data.total > 0
        && request.resource.data.get('items', []).size() > 0
        && request.resource.data.keys().hasOnly([
            'userId','userEmail','userName','items','subtotal',
            'bulkDiscount','bulkRuleId','voucherDiscount','discount',
            'voucherCode','total','paymentMethod','status','createdAt','idempotencyKey'
           ]);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Topups ────────────────────────────────────────────────────────
    match /topups/{topupId} {
      allow read: if (isAuthenticated() && isOwner(resource.data.userId)) || isAdmin();
      allow create: if !isAuthenticated()
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 50000000
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0;
      allow update: if isAdmin()
        || (!isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status','autoApproved','sePayId','gateway','referenceCode','approvedAt']));
      allow delete: if false;
    }

    // ── Transactions ──────────────────────────────────────────────────
    match /transactions/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if !isAuthenticated() || isAdmin();
      allow update, delete: if false;
    }

    // ── Vouchers ──────────────────────────────────────────────────────
    // FIX 2025-C: read restricted to own userId or admin — prevents listing all vouchers
    // (previously any authenticated user could list all vouchers including targeted ones)
    match /vouchers/{voucherId} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
              !resource.data.keys().hasAny(['targetUserId']) ||
              resource.data.get('targetUserId', '') == '' ||
              resource.data.targetUserId == request.auth.uid
            ));
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usedCount', 'usedBy']) &&
            request.resource.data.usedCount == resource.data.usedCount + 1 &&
            // FIX 2025-J: verify added email == auth user's actual email
            // Prevents attacker adding victim email to block their voucher access
            request.resource.data.usedBy.hasAll(resource.data.get('usedBy', [])) &&
            request.resource.data.usedBy.size() == resource.data.get('usedBy', []).size() + 1 &&
            request.resource.data.usedBy.hasAll([request.auth.token.email]));
    }

    // ── Game Types ────────────────────────────────────────────────────
    match /gameTypes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Flash Sales ───────────────────────────────────────────────────
    match /flashSales/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Bulk Discount Rules ───────────────────────────────────────────
    match /bulkDiscountRules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Services ──────────────────────────────────────────────────────
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Service Orders ────────────────────────────────────────────────
    match /serviceOrders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.get('amount', 0) >= 0;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Unmatched Topups ──────────────────────────────────────────────
    match /unmatchedTopups/{id} {
      allow read: if isAdmin();
      allow create: if !isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── Processed Webhooks ────────────────────────────────────────────
    // FIX 2025-D: removed !isAuthenticated() read — only admin/server should see this
    match /processedWebhooks/{id} {
      allow read: if isAdmin();
      allow create: if !isAuthenticated();
      allow update: if !isAuthenticated();
      allow delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────
    // FIX 2025-E: read now scoped to OWN notifications only (not all notifications)
    //             Any auth user could previously read every notification in the collection.
    // FIX 2025-F: create now requires targetUserId == request.auth.uid
    //             Previously any auth user could create a notification targeting ANY other user.
    match /notifications/{id} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
              resource.data.get('targetAll', false) == true ||
              resource.data.get('targetUserId', '') == request.auth.uid
            ));
      allow create: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.targetAll == false
            && request.resource.data.createdBy == 'system'
            // FIX 2025-F: can only target yourself (server creates cross-user notifications)
            && request.resource.data.get('targetUserId', request.auth.uid) == request.auth.uid);
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
    }

    // ── Tickets ───────────────────────────────────────────────────────
    match /tickets/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Referrals ─────────────────────────────────────────────────────
    // FIX 2025-G: update rule tightened — previously !isAuthenticated() allowed ANY
    //             anonymous REST request to update ANY referral doc (mark credited=true
    //             to block commission, or tamper with referrerId).
    //             Now: only admin or unauthenticated server updating ONLY safe fields.
    match /referrals/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.newUserId == request.auth.uid ||
         resource.data.referrerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.newUserId == request.auth.uid
        && request.resource.data.credited == false
        && request.resource.data.referrerId != request.auth.uid;
      // Server (unauthenticated) can only update credited + audit fields, not referrerId/newUserId
      allow update: if isAdmin()
        || (!isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['credited','creditedAt','commissionAmount','commissionPct',
                        'topupAmount','creditNote']));
      allow delete: if false;
    }

    // ── Ratings ───────────────────────────────────────────────────────
    // FIX 2025-N: Firestore rules cannot cross-collection query to verify purchase.
    // Server-side: RatingWidget does a re-verify getDoc before addDoc.
    // Additional protection: orderId is required in the rating doc (proof of purchase link).
    // Admin can delete fake ratings. Full enforcement requires a Cloud Function trigger.
    match /ratings/{id} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('stars', 0) >= 1
        && request.resource.data.get('stars', 0) <= 5
        && request.resource.data.get('comment', '').size() <= 500
        // Require orderId to be present (proof of purchase reference)
        && request.resource.data.keys().hasAny(['orderId'])
        && request.resource.data.get('orderId', '').size() > 0;
      allow update, delete: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Wishlists ─────────────────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Audit Log ─────────────────────────────────────────────────────
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
