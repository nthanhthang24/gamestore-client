rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId)   { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Accounts: public read, admin write ──
    match /accounts/{accountId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        // ✅ Bất kỳ ai (kể cả guest) được tăng views
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
          request.resource.data.views == resource.data.views + 1) ||
        // ✅ CHECKOUT: user được set status='sold' nhưng KHÔNG được set về 'available'
        // (chỉ admin mới reset được — bảo vệ chống kẻ tấn công "unlock" account)
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          resource.data.status == 'available' &&
          request.resource.data.status == 'sold');
    }

    // ── Users: field-level protection - KHÔNG cho user tự sửa balance/role ──
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.balance == 0;
      allow update: if isAdmin() ||
        (isOwner(userId) &&
          !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['balance', 'role', 'uid', 'createdAt']));
    }

    // ── Orders: user tạo và đọc của mình, admin đọc/sửa tất cả ──
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.paymentMethod == 'balance'
        && request.resource.data.total >= 0; // ✅ FIX: chặn tạo order với total âm
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Topups: user đọc của mình, SERVER tạo (không có auth), admin approve ──
    match /topups/{topupId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // ✅ Server (Render) tạo topup bằng API Key (không có Firebase Auth)
      // Validate chặt: status phải là pending, amount > 0
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.amount > 0
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Vouchers: authenticated read, admin write ──
    // ✅ FIX: Merge 2 allow update thành 1 với OR logic
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      // Admin có thể sửa tất cả; user chỉ được tăng usedCount +1 (checkout)
      allow update: if isAdmin() ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']) &&
          request.resource.data.usedCount == resource.data.usedCount + 1);
    }

    // ── Flash Sales: public read, admin write ──
    match /flashSales/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Bulk Discount Rules: authenticated read, admin write ──
    match /bulkDiscountRules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Services: public read, admin write ──
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Service Orders: user tạo/đọc của mình, admin đọc/sửa tất cả ──
    match /serviceOrders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Transactions: read-only for owner/admin, NO client write ──
    match /transactions/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // chỉ server (backend) ghi
    }

    // ── Unmatched Topups: chỉ admin ──
    match /unmatchedTopups/{id} {
      allow read, write: if isAdmin();
    }
  }
}
