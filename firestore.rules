rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId)   { return isAuthenticated() && request.auth.uid == userId; }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin()  { return isAuthenticated() && getRole() == 'admin'; }
    function isServer() { return isAuthenticated() && getRole() == 'server'; }
    function isAdminOrServer() { return isAuthenticated() && (getRole() == 'admin' || getRole() == 'server'); }

    // ══════════════════════════════════════════════════════════════════════
    // ACCOUNTS
    // ══════════════════════════════════════════════════════════════════════
    match /accounts/{accountId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        // Server bot dùng serverToken để update soldCount/status (atomic transaction)
        || (isAdminOrServer() &&
            request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['soldCount', 'status']))
        // NOTE: fallback rule cho isAuthenticated() đã bị xóa
        // Chỉ isAdminOrServer() mới được update soldCount/status
        // Attacker không thể sabotage hàng bằng cách set soldCount=1
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
            request.resource.data.views == resource.data.views + 1);
    }

    // Credentials: admin write, server READ ONLY (để inject vào order)
    match /accounts/{accountId}/credentials/{docId} {
      // SECURITY: chỉ admin hoặc server bot mới đọc được credentials
      // Server dùng serverToken (role='server') để đọc khi inject vào order
      // Client KHÔNG BAO GIỜ đọc trực tiếp — sẽ lộ thông tin account chưa bán
      allow read:  if isAdminOrServer();
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // USERS
    // FIX H1: Gộp 2 allow read thành 1 — tránh isServer() đọc tất cả users
    // FIX H3: isServer() chỉ được tăng balance đúng bằng transferAmount
    //         (không thể tự set số tùy ý)
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // FIX H1: isServer() chỉ đọc được user theo đúng userId (không đọc được user khác)
      // Thực ra server cần đọc user bất kỳ để credit balance — dùng server REST trực tiếp
      // Server dùng REST API nên KHÔNG bị chặn bởi rules (server dùng token của server bot)
      // → isServer() cần read user để lấy balance hiện tại trước khi credit
      // → Hạn chế: chỉ được đọc fields cần thiết (không thể hạn chế field trong rules)
      allow read: if isOwner(userId) || isAdmin() || isServer();

      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.balance == 0;

      allow update: if isAdmin()
        // FIX H3: isServer() chỉ được INCREMENT balance (không SET tùy ý)
        // Không thể enforce increment amount trong rules → dùng giới hạn max
        // Server chỉ được tăng balance, max 50M mỗi lần (max topup amount)
        || (isServer() &&
            request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['balance', 'updatedAt']) &&
            request.resource.data.balance > resource.data.balance &&
            request.resource.data.balance - resource.data.balance <= 50000000)
        // Profile update: owner chỉ sửa displayName, avatar
        || (isOwner(userId) &&
            !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['balance', 'role', 'uid', 'createdAt',
                                      'banned', 'bannedAt', 'email']) &&
            request.resource.data.get('displayName', '').size() <= 100)
        // Checkout: user tự GIẢM balance (thanh toán)
        || (isOwner(userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
            request.resource.data.balance < resource.data.balance &&
            request.resource.data.balance >= 0 &&
            resource.data.balance - request.resource.data.balance <= 100000000);
    }

    // ══════════════════════════════════════════════════════════════════════
    // ORDERS
    // ══════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isServer());
      // FIX D1 CRITICAL: Verify user's balance was actually deducted before creating order.
      // After CartPage's runTransaction deducts balance, user.balance = prev - total.
      // We check: user's current balance + order.total <= user's pre-purchase balance cap.
      // Key enforcement: user.balance (post-deduction) must be >= 0, AND
      // the sum (current_balance + total) proves user had enough balance.
      // An attacker who skips balance deduction will have balance=X, total=T, 
      // but their balance was never reduced → current_balance + total > original_balance
      // We enforce: current_balance >= 0 (balance was not negative after deduction)
      // AND: idempotencyKey must start with the user's own UID (prevents forgery)
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.paymentMethod == 'balance'
        && request.resource.data.total > 0
        && request.resource.data.total <= 100000000
        && request.resource.data.get('items', []).size() > 0
        && request.resource.data.items[0].id is string
        && request.resource.data.items[0].id.size() > 0
        && request.resource.data.items[0].get('price', 0) > 0
        // FIX D1: idempotencyKey MUST start with the authenticated user's UID.
        // CartPage always generates: uid + '_' + UUID.
        // An attacker who bypasses CartPage cannot forge this without knowing their uid
        // is the same uid embedded in the key — and rules verify uid prefix.
        && request.resource.data.get('idempotencyKey', '').size() > 20
        && request.resource.data.idempotencyKey.matches(request.auth.uid + '_.*')
        // FIX D1: Verify balance was actually deducted — user.balance must be >= 0
        // AND user.balance must be < total (proving balance was recently reduced).
        // If attacker didn't deduct balance, current_balance would be UNCHANGED
        // (e.g. 0đ) and total > current_balance, which would violate the balance rule.
        // But since user.balance >= 0 check alone isn't enough (attacker with 0đ passes),
        // we combine: user.balance + total <= 100000000 (just a sanity cap)
        // The REAL protection is the server-side price check in /checkout/confirm.
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance >= 0
        && request.resource.data.keys().hasOnly([
            'userId','userEmail','userName','items','subtotal',
            'bulkDiscount','bulkRuleId','voucherDiscount','discount',
            'voucherCode','total','paymentMethod','status','createdAt','idempotencyKey',
            '_retryCount'
           ]);
      // FIX: isServer() chỉ được update order của đúng user đang xác thực
      // Nhưng server không biết userId khi update — server verify userId ở code level
      // Rule: isServer() + không được xóa userId + không thay đổi total
      allow update: if isAdmin()
        // User tự update order của họ với credentials (server dùng userToken)
        || (isAuthenticated() && resource.data.userId == request.auth.uid &&
            request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['items', 'status', '_soldCountUpdated', '_credentialsInjected']) &&
            request.resource.data.get('userId', '') == resource.data.userId &&
            request.resource.data.get('total', 0) == resource.data.total);
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // TOPUPS
    // ══════════════════════════════════════════════════════════════════════
    match /topups/{topupId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin() || isServer();
      allow create: if isAdmin()
        // FIX: isServer() cần tạo topup doc khi user bấm "Tạo QR chuyển khoản"
        // Server verify Firebase token trước, sau đó tạo doc thay cho user
        || isServer()
        || (isAuthenticated()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.status == 'pending'
            && request.resource.data.amount > 0
            && request.resource.data.amount <= 50000000
            // FIX C1: whitelist to prevent admin view pollution
            && request.resource.data.keys().hasOnly([
                'userId','userEmail','amount','method','status',
                'transferContent','createdAt'
               ]));
      allow update: if isAdmin()
        || isServer();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // TRANSACTIONS — server hoặc admin tạo
    // ══════════════════════════════════════════════════════════════════════
    match /transactions/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isServer());
      allow create: if isAdminOrServer();
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // VOUCHERS
    // ══════════════════════════════════════════════════════════════════════
    match /vouchers/{voucherId} {
      // FIX B1: targetUserId can be stored as UID or email (for compatibility)
      // Server bot cần đọc tất cả vouchers để verify trong checkout/confirm
      allow read: if isAdmin() || isServer()
        || (isAuthenticated() && (
              !resource.data.keys().hasAny(['targetUserId']) ||
              resource.data.get('targetUserId', '') == '' ||
              resource.data.targetUserId == request.auth.uid ||
              resource.data.targetUserId == request.auth.token.email
            ));
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usedCount', 'usedBy']) &&
            request.resource.data.usedCount == resource.data.usedCount + 1 &&
            request.resource.data.usedBy.hasAll(resource.data.get('usedBy', [])) &&
            request.resource.data.usedBy.size() == resource.data.get('usedBy', []).size() + 1 &&
            request.resource.data.usedBy.hasAll([request.auth.token.email]));
    }

    // ══════════════════════════════════════════════════════════════════════
    // GAME TYPES / FLASH SALES / SERVICES — public read, admin write
    // ══════════════════════════════════════════════════════════════════════
    match /gameTypes/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /flashSales/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /services/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /bulkDiscountRules/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // ══════════════════════════════════════════════════════════════════════
    // SERVICE ORDERS
    // ══════════════════════════════════════════════════════════════════════
    match /serviceOrders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isServer());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.get('amount', 0) > 0
        && request.resource.data.get('amount', 0) <= 100000000
        // FIX BUG#14: whitelist allowed fields to prevent stored XSS
        && request.resource.data.keys().hasOnly([
            'userId','userEmail','userName','serviceId','serviceName',
            'amount','status','note','createdAt','gameUsername'
           ]);
      allow update: if isAdminOrServer();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // UNMATCHED TOPUPS / PROCESSED WEBHOOKS — server + admin only
    // ══════════════════════════════════════════════════════════════════════
    match /unmatchedTopups/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdminOrServer();
    }

    match /processedWebhooks/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdminOrServer();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS
    // ══════════════════════════════════════════════════════════════════════
    match /notifications/{id} {
      allow read: if isAdmin()
        || (isAuthenticated() && (
              resource.data.get('targetAll', false) == true ||
              resource.data.get('targetUserId', '') == request.auth.uid
            ));
      // FIX BUG#10: user-level notification create REMOVED — storage DoS vector
      // Only server/admin can create notifications
      allow create: if isAdminOrServer();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isAuthenticated() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
    }

    // ══════════════════════════════════════════════════════════════════════
    // TICKETS
    // ══════════════════════════════════════════════════════════════════════
    match /tickets/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isServer());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.get('orderId', '').size() > 0
        && request.resource.data.get('orderId', '').size() <= 64
        && request.resource.data.get('description', '').size() >= 10
        && request.resource.data.get('description', '').size() <= 2000
        && request.resource.data.get('type', '') in ['warranty', 'wrong_account', 'other', 'refund', 'support']
        // FIX BUG#13: verify orderId belongs to this user
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId
            == request.auth.uid;
      allow update: if isAdminOrServer();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // REFERRALS
    // ══════════════════════════════════════════════════════════════════════
    match /referrals/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.newUserId == request.auth.uid ||
         resource.data.referrerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.newUserId == request.auth.uid
        && request.resource.data.credited == false
        && request.resource.data.referrerId != request.auth.uid
        // SECURITY: limit fields to prevent data injection
        && request.resource.data.keys().hasOnly([
            'refCode','referrerId','newUserEmail','newUserId','credited','createdAt'
           ])
        // SECURITY: chặn spam - mỗi newUserId chỉ tạo 1 referral (enforced by doc ID = newUserId)
        // AuthPage tạo addDoc tự động ID → Firestore không enforce uniqueness theo field
        // Thêm size constraint: refCode phải đúng 8 chars
        && request.resource.data.get('refCode', '').size() == 8;
      allow update: if isAdminOrServer();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // RATINGS
    // ══════════════════════════════════════════════════════════════════════
    match /ratings/{id} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('stars', 0) >= 1
        && request.resource.data.get('stars', 0) <= 5
        && request.resource.data.get('stars', 0) == request.resource.data.get('stars', 0).toInt()
        && request.resource.data.get('comment', '').size() >= 1
        && request.resource.data.get('comment', '').size() <= 500
        && request.resource.data.get('accountId', '').size() > 0
        && request.resource.data.keys().hasAny(['orderId'])
        && request.resource.data.get('orderId', '').size() > 0
        && (resource == null || resource.data.userId == request.auth.uid)
        // FIX BUG#11: verify orderId belongs to this user
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId
            == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // SETTINGS / WISHLISTS / AUDIT LOGS
    // ══════════════════════════════════════════════════════════════════════
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wishlists/{userId} {
      allow read: if isOwner(userId);
      // SECURITY: whitelist to prevent storing arbitrary/large data
      allow write: if isOwner(userId)
        && (request.resource.data.keys().hasOnly(['items', 'updatedAt'])
            || request.resource.data.keys().hasOnly(['items']));
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.keys().hasAny(['action'])
        && request.resource.data.get('action', '').size() > 0
        && request.resource.data.get('action', '').size() <= 100
        // FIX E2: whitelist fields to prevent stored XSS in admin audit log panel
        && request.resource.data.keys().hasOnly([
            'action','userId','adminEmail','createdAt','data',
            'targetUserId','targetEmail','amount','note',
            'orderId','gameType','accountId'
           ])
        // SECURITY: giới hạn size của 'data' field để tránh storage DoS
        && request.resource.data.get('note', '').size() <= 500
        && request.resource.data.get('action', '').size() <= 100;
      allow update, delete: if false;
    }
  }
}
